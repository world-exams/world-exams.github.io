---
/**
 * Main infographic showing the ICFES exam system structure.
 * Updated to avoid unsupported claims and to include Saber 7°.
 */
---

<div class="infographic-wrapper">
  <div class="infographic-container" id="infographic-trigger">
    <div class="expand-hint">
      <span>Tap para ampliar infografía</span>
    </div>
    <svg viewBox="0 0 900 540" class="w-full" aria-labelledby="icfes-structure-title" role="img">
      <title id="icfes-structure-title">Estructura del Sistema de Evaluación ICFES</title>

      <rect width="900" height="540" fill="#1a1a1a"/>

      <text x="450" y="42" fill="#F5F5DC" font-size="18" font-weight="bold" text-anchor="middle" font-family="monospace">
        SISTEMA DE EVALUACIÓN ICFES
      </text>
      <text x="450" y="64" fill="#777" font-size="10" text-anchor="middle" font-family="monospace">
        Resumen visual para Colombia con foco en Saber 11.º
      </text>

      <line x1="90" y1="125" x2="780" y2="125" stroke="#F5F5DC" stroke-width="3"/>

      <circle cx="140" cy="125" r="24" fill="#1a1a1a" stroke="#F5F5DC" stroke-width="2"/>
      <text x="140" y="130" fill="#F5F5DC" font-size="13" font-weight="bold" text-anchor="middle" font-family="monospace">3°</text>
      <text x="140" y="92" fill="#888" font-size="10" text-anchor="middle">SABER 3°</text>

      <circle cx="270" cy="125" r="24" fill="#1a1a1a" stroke="#F5F5DC" stroke-width="2"/>
      <text x="270" y="130" fill="#F5F5DC" font-size="13" font-weight="bold" text-anchor="middle" font-family="monospace">5°</text>
      <text x="270" y="92" fill="#888" font-size="10" text-anchor="middle">SABER 5°</text>

      <circle cx="400" cy="125" r="24" fill="#1a1a1a" stroke="#F5F5DC" stroke-width="2"/>
      <text x="400" y="130" fill="#F5F5DC" font-size="13" font-weight="bold" text-anchor="middle" font-family="monospace">7°</text>
      <text x="400" y="92" fill="#888" font-size="10" text-anchor="middle">SABER 7°</text>

      <circle cx="530" cy="125" r="24" fill="#1a1a1a" stroke="#F5F5DC" stroke-width="2"/>
      <text x="530" y="130" fill="#F5F5DC" font-size="13" font-weight="bold" text-anchor="middle" font-family="monospace">9°</text>
      <text x="530" y="92" fill="#888" font-size="10" text-anchor="middle">SABER 9°</text>

      <circle cx="710" cy="125" r="34" fill="#F5F5DC" stroke="#F5F5DC" stroke-width="3"/>
      <text x="710" y="132" fill="#121212" font-size="18" font-weight="bold" text-anchor="middle" font-family="monospace">11°</text>
      <text x="710" y="82" fill="#F5F5DC" font-size="12" font-weight="bold" text-anchor="middle">EXAMEN DE ESTADO</text>

      <line x1="140" y1="149" x2="140" y2="184" stroke="#555" stroke-width="1" stroke-dasharray="4"/>
      <line x1="270" y1="149" x2="270" y2="184" stroke="#555" stroke-width="1" stroke-dasharray="4"/>
      <line x1="400" y1="149" x2="400" y2="184" stroke="#555" stroke-width="1" stroke-dasharray="4"/>
      <line x1="530" y1="149" x2="530" y2="184" stroke="#555" stroke-width="1" stroke-dasharray="4"/>
      <line x1="710" y1="159" x2="710" y2="184" stroke="#F5F5DC" stroke-width="2"/>

      <rect x="70" y="188" width="130" height="126" fill="none" stroke="#555" stroke-width="1" rx="4"/>
      <text x="135" y="212" fill="#F5F5DC" font-size="11" text-anchor="middle" font-weight="bold">Diagnóstico</text>
      <line x1="90" y1="222" x2="180" y2="222" stroke="#555" stroke-width="0.5"/>
      <text x="135" y="242" fill="#888" font-size="9" text-anchor="middle">• Matemáticas</text>
      <text x="135" y="258" fill="#888" font-size="9" text-anchor="middle">• Lenguaje</text>
      <text x="135" y="288" fill="#666" font-size="8" text-anchor="middle">Aplicación muestral</text>

      <rect x="205" y="188" width="130" height="126" fill="none" stroke="#555" stroke-width="1" rx="4"/>
      <text x="270" y="212" fill="#F5F5DC" font-size="11" text-anchor="middle" font-weight="bold">Primaria</text>
      <line x1="225" y1="222" x2="315" y2="222" stroke="#555" stroke-width="0.5"/>
      <text x="270" y="240" fill="#888" font-size="9" text-anchor="middle">• Matemáticas</text>
      <text x="270" y="254" fill="#888" font-size="9" text-anchor="middle">• Lenguaje</text>
      <text x="270" y="268" fill="#888" font-size="9" text-anchor="middle">• Cuestionario</text>
      <text x="270" y="288" fill="#666" font-size="8" text-anchor="middle">Aplicación muestral</text>

      <rect x="340" y="188" width="130" height="126" fill="none" stroke="#555" stroke-width="1" rx="4"/>
      <text x="405" y="212" fill="#F5F5DC" font-size="11" text-anchor="middle" font-weight="bold">Seguimiento</text>
      <line x1="360" y1="222" x2="450" y2="222" stroke="#555" stroke-width="0.5"/>
      <text x="405" y="240" fill="#888" font-size="9" text-anchor="middle">• Matemáticas</text>
      <text x="405" y="254" fill="#888" font-size="9" text-anchor="middle">• Lectura</text>
      <text x="405" y="268" fill="#888" font-size="9" text-anchor="middle">• Cuestionario</text>
      <text x="405" y="288" fill="#666" font-size="8" text-anchor="middle">Aplicación muestral</text>

      <rect x="475" y="188" width="130" height="126" fill="none" stroke="#555" stroke-width="1" rx="4"/>
      <text x="540" y="212" fill="#F5F5DC" font-size="11" text-anchor="middle" font-weight="bold">Fin básica</text>
      <line x1="495" y1="222" x2="585" y2="222" stroke="#555" stroke-width="0.5"/>
      <text x="540" y="240" fill="#888" font-size="9" text-anchor="middle">• Matemáticas</text>
      <text x="540" y="254" fill="#888" font-size="9" text-anchor="middle">• Lectura</text>
      <text x="540" y="268" fill="#888" font-size="9" text-anchor="middle">• Cuestionario</text>
      <text x="540" y="288" fill="#666" font-size="8" text-anchor="middle">Aplicación muestral</text>

      <rect x="620" y="188" width="190" height="220" fill="#F5F5DC" fill-opacity="0.1" stroke="#F5F5DC" stroke-width="2" rx="4"/>
      <text x="715" y="212" fill="#F5F5DC" font-size="12" text-anchor="middle" font-weight="bold">SABER 11.º</text>
      <line x1="640" y1="222" x2="790" y2="222" stroke="#F5F5DC" stroke-width="0.5" opacity="0.5"/>
      <text x="715" y="243" fill="#F5F5DC" font-size="9" text-anchor="middle">• Lectura Crítica</text>
      <text x="715" y="258" fill="#F5F5DC" font-size="9" text-anchor="middle">• Matemáticas</text>
      <text x="715" y="273" fill="#F5F5DC" font-size="9" text-anchor="middle">• Sociales y Ciudadanas</text>
      <text x="715" y="288" fill="#F5F5DC" font-size="9" text-anchor="middle">• Ciencias Naturales</text>
      <text x="715" y="303" fill="#F5F5DC" font-size="9" text-anchor="middle">• Inglés</text>
      <line x1="640" y1="316" x2="790" y2="316" stroke="#F5F5DC" stroke-width="0.5" opacity="0.5"/>
      <text x="715" y="338" fill="#F5F5DC" font-size="9" text-anchor="middle" font-weight="bold">230 preguntas calificables</text>
      <text x="715" y="353" fill="#F5F5DC" font-size="9" text-anchor="middle">278 con cuestionario socioeconómico</text>
      <text x="715" y="368" fill="#F5F5DC" font-size="9" text-anchor="middle">2 sesiones de 4 h 30</text>
      <text x="715" y="390" fill="#F5F5DC" font-size="8" text-anchor="middle" opacity="0.7">Lo presentan quienes finalizan</text>
      <text x="715" y="402" fill="#F5F5DC" font-size="8" text-anchor="middle" opacity="0.7">grado 11.º y población habilitada</text>

      <text x="205" y="452" fill="#555" font-size="10" text-anchor="middle">BÁSICA PRIMARIA</text>
      <line x1="70" y1="438" x2="335" y2="438" stroke="#555" stroke-width="1"/>

      <text x="470" y="452" fill="#555" font-size="10" text-anchor="middle">BÁSICA SECUNDARIA</text>
      <line x1="340" y1="438" x2="605" y2="438" stroke="#555" stroke-width="1"/>

      <text x="715" y="452" fill="#888" font-size="10" text-anchor="middle">MEDIA</text>
      <line x1="620" y1="438" x2="810" y2="438" stroke="#888" stroke-width="1"/>

      <rect x="95" y="485" width="12" height="12" fill="#F5F5DC"/>
      <text x="115" y="495" fill="#888" font-size="10">= bloque destacado del examen de Estado</text>

      <rect x="420" y="485" width="12" height="12" fill="none" stroke="#555" stroke-width="1"/>
      <text x="440" y="495" fill="#888" font-size="10">= referencia del sistema de evaluación</text>
    </svg>
  </div>

  <!-- Lightbox Overlay -->
  <div id="infographic-lightbox" class="lightbox">
    <div class="lightbox-toolbar">
      <span class="lightbox-title">Estructura ICFES</span>
      <button id="lightbox-close" class="close-btn" aria-label="Cerrar infografía">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
          <path d="M18 6L6 18M6 6l12 12"/>
        </svg>
      </button>
    </div>
    <div class="lightbox-content">
      <div id="infographic-clone-container"></div>
    </div>
    <div class="lightbox-footer">
      <span>Desliza para explorar</span>
    </div>
  </div>
</div>

<script>
  const trigger = document.getElementById('infographic-trigger');
  const lightbox = document.getElementById('infographic-lightbox');
  const closeBtn = document.getElementById('lightbox-close');
  const cloneContainer = document.getElementById('infographic-clone-container');

  if (trigger && lightbox && closeBtn && cloneContainer) {
    trigger.addEventListener('click', () => {
      // Clone the SVG for the lightbox
      const svg = trigger.querySelector('svg');
      if (svg) {
        const clone = svg.cloneNode(true);
        cloneContainer.innerHTML = '';
        cloneContainer.appendChild(clone);
        lightbox.classList.add('active');
        document.body.style.overflow = 'hidden'; // Lock scroll
      }
    });

    const closeLightbox = () => {
      lightbox.classList.remove('active');
      document.body.style.overflow = '';
      setTimeout(() => {
        cloneContainer.innerHTML = '';
      }, 300);
    };

    closeBtn.addEventListener('click', (e) => {
      e.stopPropagation();
      closeLightbox();
    });

    lightbox.addEventListener('click', (e) => {
      const target = e.target as HTMLElement;
      if (target === lightbox || target.classList?.contains('lightbox-content')) {
        closeLightbox();
      }
    });

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && lightbox.classList.contains('active')) {
        closeLightbox();
      }
    });
  }
</script>

<style>
  .infographic-wrapper {
    position: relative;
    width: 100%;
  }

  .infographic-container {
    background-color: #1a1a1a;
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 12px;
    padding: 1rem;
    cursor: pointer;
    transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
    position: relative;
    overflow: hidden;
  }

  .infographic-container:hover {
    border-color: rgba(16, 185, 129, 0.3);
    background-color: #1e1e1e;
    transform: translateY(-2px);
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.3);
  }

  .expand-hint {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(0, 0, 0, 0.6);
    backdrop-filter: blur(2px);
    opacity: 0;
    transition: opacity 0.3s;
    z-index: 10;
    pointer-events: none;
  }

  .infographic-container:hover .expand-hint {
    opacity: 1;
  }

  .expand-hint span {
    background: #10b981;
    color: #000;
    padding: 0.5rem 1rem;
    border-radius: 99px;
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    transform: translateY(10px);
    transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .infographic-container:hover .expand-hint span {
    transform: translateY(0);
  }

  /* SVG Specific */
  .infographic-container svg {
    width: 100%;
    height: auto;
    display: block;
  }

  /* Lightbox */
  .lightbox {
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.95);
    z-index: 1000000;
    display: flex;
    flex-direction: column;
    opacity: 0;
    visibility: hidden;
    transition: all 0.3s ease;
    backdrop-filter: blur(10px);
  }

  .lightbox.active {
    opacity: 1;
    visibility: visible;
  }

  .lightbox-toolbar {
    padding: 1.5rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
  }

  .lightbox-title {
    font-weight: 700;
    color: #10b981;
    font-family: 'Fira Code', monospace;
  }

  .close-btn {
    color: #fff;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.1);
    width: 44px;
    height: 44px;
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.2s;
  }

  .close-btn:hover {
    background: rgba(239, 68, 68, 0.2);
    border-color: rgba(239, 68, 68, 0.3);
    color: #ef4444;
  }

  .lightbox-content {
    flex: 1;
    overflow: auto;
    display: flex;
    align-items: center;
    padding: 1rem;
    cursor: grab;
  }

  .lightbox-content:active {
    cursor: grabbing;
  }

  #infographic-clone-container {
    min-width: 900px; /* Force minimum width for horizontal scroll */
    margin: auto;
  }

  .lightbox-footer {
    padding: 1rem;
    text-align: center;
    color: rgba(255, 255, 255, 0.4);
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    border-top: 1px solid rgba(255, 255, 255, 0.05);
  }

  @media (max-width: 768px) {
    .expand-hint {
      opacity: 1;
      background: linear-gradient(to top, rgba(0,0,0,0.8), transparent 40%);
      align-items: flex-end;
      padding-bottom: 1.5rem;
    }

    .expand-hint span {
      transform: none;
      box-shadow: 0 4px 15px rgba(16, 185, 129, 0.3);
    }
  }
</style>
