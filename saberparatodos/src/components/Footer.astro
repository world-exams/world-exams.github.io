---
/**
 * Global Footer Component
 * Estilo minimalista con enlaces y créditos
 */

const currentYear = new Date().getFullYear();

const footerLinks = {
  recursos: [
    { href: "/", label: "Inicio" },
    { href: "/manual-plataforma", label: "Manual de Uso" },
    { href: "/guia-examen", label: `Guía ${countryConfig.code === 'MX' ? 'EXANI' : 'ICFES'} 2026` },
    { href: "/changelog", label: "Changelog & Versiones" },
    { href: "/sobre-nosotros", label: "Sobre Nosotros" },
    { href: "/contacto", label: "Contacto" },
  ],
  legal: [
    { href: "/terminos", label: "Términos de Uso" },
    { href: "/privacy", label: "Política de Privacidad" },
    { href: "/developers", label: "Developer API" },
  ],
  social: [
    { href: "https://github.com/world-exams", label: "GitHub", icon: "github" },
  ],
};

import { countryConfig } from '../config';

// Helper for dynamic badge logic needs to be available in template
const configs = { 'MX': { code: 'MX' }, 'CO': { code: 'CO' } }; // Simplified for template access logic
const getCountryCode = () => countryConfig.code;
---

<footer class="footer">
  <div class="footer-container">
    <!-- Main Footer Content -->
    <div class="footer-grid">
      <!-- Brand Section -->
      <div class="footer-brand">
        <div class="brand-logo">
          <svg
            width="40"
            height="40"
            viewBox="0 0 40 40"
            fill="none"
            xmlns="http://www.w3.org/2000/svg"
            aria-hidden="true"
          >
            <rect
              width="40"
              height="40"
              rx="6"
              fill={countryConfig.theme.bgDark}
              stroke={countryConfig.theme.primary}
              stroke-width="1.5"></rect>
            <text
              x="20"
              y="26"
              fill={countryConfig.theme.primary}
              font-size="16"
              font-weight="bold"
              text-anchor="middle"
              font-family="monospace">WE</text
            >
          </svg>
          <span class="brand-name">World Exams</span>
        </div>
        <p class="brand-description">
          Plataforma open source de práctica para {countryConfig.name}.
          Contenido gratuito para todos los estudiantes.
        </p>
        <div class="brand-badge">
          <span class="badge" style={`color: ${countryConfig.theme.primary}; border-color: ${countryConfig.theme.primary}`}>
            {configs[getCountryCode() as keyof typeof configs].code === 'MX' ? '🇲🇽' : '🇨🇴'} Versión {countryConfig.name}
          </span>
        </div>
      </div>

      <!-- Resources Links -->
      <div class="footer-section">
        <h3 class="section-title">Recursos</h3>
        <ul class="link-list">
          {
            footerLinks.recursos.map((link) => (
              <li>
                <a href={link.href} class="footer-link">
                  {link.label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <!-- Legal Links -->
      <div class="footer-section">
        <h3 class="section-title">Legal</h3>
        <ul class="link-list">
          {
            footerLinks.legal.map((link) => (
              <li>
                <a href={link.href} class="footer-link">
                  {link.label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <!-- Social Links -->
      <div class="footer-section">
        <h3 class="section-title">Comunidad</h3>
        <div class="social-links">
          <a
            href="https://github.com/world-exams"
            target="_blank"
            rel="noopener noreferrer"
            class="social-link"
            aria-label="GitHub"
          >
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
              <path
                d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"
              ></path>
            </svg>
          </a>
        </div>
      </div>
    </div>

    <!-- Divider -->
    <div class="footer-divider"></div>

    <!-- Bottom Bar -->
    <div class="footer-bottom">
      <p class="copyright">
        © {currentYear} {countryConfig.name}. Powered by <a
          href="https://github.com/world-exams"
          target="_blank"
          rel="noopener noreferrer">World Exams Organization</a
        >
      </p>
      <p class="disclaimer">
        No afiliado oficialmente con {countryConfig.institucion}. Contenido educativo basado en
        información pública.
      </p>
    </div>
  </div>

  <!-- Flag Stripe Bottom -->
  <div class="flag-stripe" aria-hidden="true">
    <div class="stripe" style={`background-color: ${countryConfig.theme.primary}; flex: 2`}></div>
    <div class="stripe" style={`background-color: ${countryConfig.theme.secondary}; flex: 1`}></div>
    <div class="stripe" style={`background-color: ${countryConfig.theme.accent}; flex: 1`}></div>
  </div>
</footer>

<style>
  .footer {
    background-color: #0a0a0a;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    margin-top: auto;
  }

  .footer-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 3rem 1rem 1rem;
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
  }

  @media (min-width: 640px) {
    .footer-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .footer-grid {
      grid-template-columns: 2fr 1fr 1fr 1fr;
    }
  }

  /* Brand Section */
  .footer-brand {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .brand-logo {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .brand-name {
    font-family: "Fira Code", monospace;
    font-size: 1.25rem;
    font-weight: 600;
    color: #f5f5dc;
  }

  .brand-description {
    font-family: "Inter", sans-serif;
    font-size: 0.875rem;
    color: rgba(245, 245, 220, 0.6);
    line-height: 1.6;
    max-width: 300px;
  }

  .badge {
    display: inline-block;
    font-family: "Fira Code", monospace;
    font-size: 0.75rem;
    padding: 0.25rem 0.5rem;
    background-color: rgba(252, 209, 22, 0.1);
    border: 1px solid rgba(252, 209, 22, 0.3);
    border-radius: 4px;
    color: #fcd116;
  }

  /* Footer Sections */
  .footer-section {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .section-title {
    font-family: "Fira Code", monospace;
    font-size: 0.875rem;
    font-weight: 600;
    color: #f5f5dc;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .link-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .footer-link {
    font-family: "Inter", sans-serif;
    font-size: 0.875rem;
    color: rgba(245, 245, 220, 0.6);
    text-decoration: none;
    transition: color 0.2s;
  }

  .footer-link:hover {
    color: #f5f5dc;
  }

  /* Social Links */
  .social-links {
    display: flex;
    gap: 1rem;
  }

  .social-link {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    background-color: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 8px;
    color: rgba(245, 245, 220, 0.6);
    transition: all 0.2s;
  }

  .social-link:hover {
    background-color: rgba(255, 255, 255, 0.1);
    color: #f5f5dc;
    border-color: rgba(255, 255, 255, 0.2);
  }

  /* Divider */
  .footer-divider {
    height: 1px;
    background: linear-gradient(
      to right,
      transparent,
      rgba(255, 255, 255, 0.1),
      transparent
    );
    margin: 2rem 0 1rem;
  }

  /* Bottom Bar */
  .footer-bottom {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    text-align: center;
  }

  @media (min-width: 768px) {
    .footer-bottom {
      flex-direction: row;
      justify-content: space-between;
      text-align: left;
    }
  }

  .copyright {
    font-family: "Inter", sans-serif;
    font-size: 0.75rem;
    color: rgba(245, 245, 220, 0.5);
  }

  .copyright a {
    color: rgba(245, 245, 220, 0.7);
    text-decoration: none;
  }

  .copyright a:hover {
    color: #f5f5dc;
  }

  .disclaimer {
    font-family: "Inter", sans-serif;
    font-size: 0.75rem;
    color: rgba(245, 245, 220, 0.4);
  }

  /* Flag Stripe */
  .flag-stripe {
    display: flex;
    height: 4px;
    width: 100%;
  }

  .stripe {
    flex: 1;
  }

  .stripe-yellow {
    background-color: #fcd116;
    flex: 2;
  }

  .stripe-blue {
    background-color: #003893;
    flex: 1;
  }

  .stripe-red {
    background-color: #ce1126;
    flex: 1;
  }
</style>
