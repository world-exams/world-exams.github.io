---
import Layout from '../layouts/Layout.astro';
import DashboardMain from '../components/dashboard/DashboardMain.svelte';

// Fast-path guard for unauthenticated users.
// If no Supabase auth cookie exists, redirect immediately without client-side JS.
const cookieHeader = Astro.request.headers.get('cookie') ?? '';
const hasSupabaseAuthCookie =
  /sb-[^=]+-auth-token=/.test(cookieHeader) || /supabase-auth-token=/.test(cookieHeader);

if (!hasSupabaseAuthCookie) {
  return Astro.redirect('/instituciones');
}
---

<Layout title="Dashboard Institucional | World Exams" description="Panel de control para instituciones educativas.">
  <div class="flex h-screen bg-zinc-50 dark:bg-black overflow-hidden" id="dashboard-app" style="display: none;">
    <!-- Sidebar -->
    <aside class="w-64 border-r border-zinc-200 dark:border-zinc-800 bg-white dark:bg-zinc-900 hidden md:flex flex-col">
      <div class="p-6 border-b border-zinc-200 dark:border-zinc-800">
        <h2 class="font-bold text-xl text-zinc-900 dark:text-white flex items-center gap-2">
          <span class="text-blue-600">⚡</span> Institucional
        </h2>
      </div>

      <nav class="flex-1 p-4 space-y-1">
        <a href="#" class="flex items-center gap-3 px-4 py-3 bg-blue-50 dark:bg-blue-900/20 text-blue-700 dark:text-blue-300 rounded-lg font-medium">
          <span>📊</span> Organizaciones
        </a>
        <a href="#" class="flex items-center gap-3 px-4 py-3 text-zinc-600 dark:text-zinc-400 hover:bg-zinc-100 dark:hover:bg-zinc-800 rounded-lg transition-colors">
          <span>⚙️</span> Configuración
        </a>
      </nav>

      <div class="p-4 border-t border-zinc-200 dark:border-zinc-800">
        <button id="logout-btn" class="flex items-center gap-3 w-full px-4 py-2 text-red-600 dark:text-red-400 hover:bg-red-50 dark:hover:bg-red-900/20 rounded-lg transition-colors text-sm font-medium">
          <span>🚪</span> Cerrar Sesión
        </button>
      </div>
    </aside>

    <!-- Main Content -->
    <main class="flex-1 overflow-auto p-8 relative">
      <header class="mb-8 flex justify-between items-center">
        <div>
          <h1 class="text-2xl font-bold text-zinc-900 dark:text-white">Panel de Control</h1>
          <p class="text-zinc-500 text-sm">Gestiona tus instituciones educativas.</p>
        </div>
        <div class="flex items-center gap-4">
          <span id="user-email" class="text-sm font-medium text-zinc-700 dark:text-zinc-300 hidden sm:block">usuario@colegio.edu.co</span>
          <div class="w-8 h-8 rounded-full bg-blue-600 flex items-center justify-center text-white text-xs font-bold">U</div>
        </div>
      </header>

      <!-- Svelte Component Mount -->
      <DashboardMain client:only="svelte" />

    </main>
  </div>

  <div id="loading-screen" class="fixed inset-0 bg-white dark:bg-black flex items-center justify-center z-50">
    <div class="animate-spin rounded-full h-12 w-12 border-t-2 border-b-2 border-blue-500"></div>
  </div>

  <script>
    import { supabase } from '../lib/supabase';

    const dashboardApp = document.getElementById('dashboard-app');
    const loadingScreen = document.getElementById('loading-screen');
    const userEmailEl = document.getElementById('user-email');
    const logoutBtn = document.getElementById('logout-btn');

    async function checkAuth() {
      const { data: { session } } = await supabase.auth.getSession();

      if (!session) {
        window.location.href = '/instituciones'; // Redirect if not logged in
        return;
      }

      const { data: membership, error: membershipError } = await supabase
        .from('organization_members')
        .select('organization_id')
        .eq('user_id', session.user.id)
        .limit(1);

      if (membershipError || !membership || membership.length === 0) {
        window.location.href = '/instituciones?noaccess=1';
        return;
      }

      // Show Dashboard
      if (userEmailEl) userEmailEl.textContent = session.user.email ?? '';
      if (dashboardApp) dashboardApp.style.display = 'flex';
      if (loadingScreen) loadingScreen.style.display = 'none';
    }

    if (logoutBtn) {
      logoutBtn.addEventListener('click', async () => {
        await supabase.auth.signOut();
        window.location.href = '/instituciones';
      });
    }

    checkAuth();
  </script>
</Layout>
