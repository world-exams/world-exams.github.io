---
import Layout from '../layouts/Layout.astro';


const TELEGRAM_BOT_USERNAME = import.meta.env.PUBLIC_TELEGRAM_BOT_USERNAME || '';
---

<Layout title="Vincular Telegram - SaberParaTodos">
  <div class="min-h-screen bg-gradient-to-br from-indigo-50 to-blue-100">
    <div class="max-w-2xl mx-auto px-4 py-10">
      <div class="bg-white rounded-xl shadow-lg p-8">
        <h1 class="text-2xl font-bold text-gray-900 mb-2">Vincular Telegram</h1>
        <p class="text-gray-600 mb-6">
          Esto hace que tu Telegram y tu correo sean el mismo usuario.
        </p>

        <div class="space-y-4 text-sm text-gray-700">
          <div class="p-4 bg-gray-50 rounded-lg border">
            <p class="font-semibold mb-1">Paso 1</p>
            <p>Inicia sesión con tu correo (enlace mágico) si aún no lo hiciste.</p>
          </div>

          <div class="p-4 bg-gray-50 rounded-lg border">
            <p class="font-semibold mb-1">Paso 2</p>
            <p>Genera un código de vinculación (expira). Luego vuelve a Telegram.</p>
          </div>

          <div class="p-4 bg-gray-50 rounded-lg border">
            <p class="font-semibold mb-1">Paso 3</p>
            <p>En el bot, envía <span class="font-mono">/start CÓDIGO</span> y quedará vinculado.</p>
          </div>
        </div>

        <div class="mt-6 flex flex-col gap-3">
          <button
            id="btn-generate"
            data-telegram-bot={TELEGRAM_BOT_USERNAME}
            class="w-full px-4 py-3 bg-blue-600 hover:bg-blue-700 text-white rounded-lg font-semibold disabled:opacity-60"
            type="button"
          >
            Generar código para Telegram
          </button>

          <div id="status" class="text-sm text-gray-600"></div>

          <div id="result" class="hidden p-4 bg-green-50 border border-green-200 rounded-lg">
            <p class="text-green-900 font-semibold mb-2">Código generado</p>
            <div class="flex items-center justify-between gap-3">
              <code id="code" class="px-3 py-2 bg-white border rounded font-mono text-lg"></code>
              <button id="btn-copy" class="px-3 py-2 bg-white border rounded hover:bg-gray-50" type="button">Copiar</button>
            </div>
            <p class="text-green-800 text-sm mt-3">
              En Telegram, envía: <span class="font-mono">/start <span id="code-inline"></span></span>
            </p>
            <a id="deep-link" class="inline-block mt-3 text-blue-700 underline font-semibold" href="#">Abrir Telegram con el código</a>
          </div>

          <div id="error" class="hidden p-3 bg-red-50 border border-red-200 rounded-lg text-sm text-red-800"></div>
        </div>

        <div class="mt-8 text-xs text-gray-500">
          <p>
            Nota: por seguridad, no vinculamos Telegram solo con un enlace. El código asegura que eres tú quien controla el correo.
          </p>
        </div>
      </div>
    </div>
  </div>
</Layout>

<script>
  import { supabase } from '../lib/supabase';

  const btn = document.getElementById('btn-generate') as HTMLButtonElement;
  const status = document.getElementById('status') as HTMLDivElement;
  const result = document.getElementById('result') as HTMLDivElement;
  const codeEl = document.getElementById('code') as HTMLElement;
  const codeInline = document.getElementById('code-inline') as HTMLElement;
  const deepLink = document.getElementById('deep-link') as HTMLAnchorElement;
  const errorEl = document.getElementById('error') as HTMLDivElement;
  const btnCopy = document.getElementById('btn-copy') as HTMLButtonElement;

  if (!btn || !status || !result || !codeEl || !codeInline || !deepLink || !errorEl || !btnCopy) {
    throw new Error('Required elements not found');
  }

  const telegramBotUsername = btn.dataset.telegramBot || '';

  function setError(msg: string) {
    errorEl.textContent = msg;
    errorEl.classList.remove('hidden');
  }

  function clearError() {
    errorEl.textContent = '';
    errorEl.classList.add('hidden');
  }

  btn.addEventListener('click', async () => {
    btn.disabled = true;
    clearError();
    result.classList.add('hidden');
    status.textContent = 'Generando código…';

    try {
      const { data: sessionData } = await supabase.auth.getSession();
      const accessToken = sessionData.session?.access_token;

      if (!accessToken) {
        status.textContent = '';
        setError('Primero inicia sesión con tu correo (enlace mágico) y vuelve a esta página.');
        btn.disabled = false;
        return;
      }

      const resp = await fetch('/api/auth/generate-link-token', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          Authorization: `Bearer ${accessToken}`,
        },
        body: JSON.stringify({ provider: 'telegram' }),
      });

      const json = await resp.json().catch(() => ({}));
      if (!resp.ok) {
        throw new Error(json?.error || 'No se pudo generar el código');
      }

      const code = json?.code || json?.linkCode || '';
      if (!code) {
        throw new Error('Respuesta inválida: falta el código');
      }

      codeEl.textContent = code;
      codeInline.textContent = code;

      if (telegramBotUsername) {
        deepLink.href = `https://t.me/${telegramBotUsername}?start=${encodeURIComponent(code)}`;
      } else {
        deepLink.href = '#';
        deepLink.addEventListener('click', (e) => e.preventDefault());
      }

      result.classList.remove('hidden');
      status.textContent = '';
    } catch (e: any) {
      status.textContent = '';
      setError(e?.message || 'Error generando el código');
    } finally {
      btn.disabled = false;
    }
  });

  btnCopy.addEventListener('click', async () => {
    const code = codeEl.textContent || '';
    if (!code) return;
    try {
      await navigator.clipboard.writeText(code);
      btnCopy.textContent = 'Copiado';
      setTimeout(() => (btnCopy.textContent = 'Copiar'), 1200);
    } catch {
      // ignore
    }
  });
</script>
