---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

// Obtener los posts del changelog para enlazarlos si es necesario
const posts = await getCollection('changelog');
posts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const title = "Historial de Versiones | SaberParaTodos";
const description = "Registro ordenado de versiones, cambios y actualizaciones de la plataforma SaberParaTodos.";

// Definición estática del historial de versiones principal
const releases = [
  {
    version: "v0.10.0",
    date: "2026-03-10",
    status: "Protocol Update",
    statusColor: "bg-[#FCD116]/20 text-[#FCD116] border-[#FCD116]/30",
    summary: "Nueva base de release para el monorepo privado con protocolo GitCore adaptado y tracking formal de features.",
    changes: [
      { type: "Nuevo", text: "Registro `.gitcore/features.json` para seguimiento de features y releases." },
      { type: "Mejora", text: "Changelog y arquitectura conectados a la versión visible del proyecto." },
      { type: "Mejora", text: "Documentación raíz y protocolos unificados para evitar desvíos de agentes." }
    ]
  },
  {
    version: "v0.3.1",
    date: "2026-03-09",
    status: "Mejora Continua",
    statusColor: "bg-emerald-500/20 text-emerald-400 border-emerald-500/20",
    summary: "Refinamiento de Inglés y comunidad interactiva.",
    changes: [
      { type: "Mejora", text: "Filtrado avanzado de preguntas de Inglés basado en niveles CEFR." },
      { type: "Nuevo", text: "Sistema de comentarios tipo foro con respuestas (hilos) en novedades." },
      { type: "Fix", text: "Corrección de errores de tipado y linting en el motor de selección." }
    ],
    postSlug: "2026-03-09-filtrado-ingles-y-comentarios"
  },
  {
    version: "v0.3.0",
    date: "2026-03-06",
    status: "Beta Abierta",
    statusColor: "bg-blue-500/20 text-blue-400 border-blue-500/30",
    summary: "Lanzamiento V3 con Testing Adaptativo en Inglés y optimización UI.",
    changes: [
      { type: "Nuevo", text: "Motor adaptativo en tiempo real para evaluar el nivel de Inglés." },
      { type: "Nuevo", text: "Modo diagnóstico mejorado con selección de nivel de dificultad inicial." },
      { type: "Mejora", text: "Interfaz principal migrada a Svelte 5 Runes para mejor rendimiento." },
      { type: "Mejora", text: "Refinamiento responsivo en Navbar y secciones de documentación." }
    ],
    postSlug: "2026-03-04-lanzamiento-adaptativo"
  },
  {
    version: "v0.2.0",
    date: "2026-01-15",
    status: "Estable",
    statusColor: "bg-emerald-500/20 text-emerald-400 border-emerald-500/30",
    summary: "Nuevas preguntas y soporte completo de áreas ICFES.",
    changes: [
      { type: "Nuevo", text: "Bases de datos ampliadas con preguntas oficiales Saber 11." },
      { type: "Nuevo", text: "Sección de Resultados y Estimación de Percentiles." },
      { type: "Mejora", text: "Diseño Glassmorphism aplicado en toda la plataforma." },
      { type: "Fix", text: "Corrección de errores menores en el guardado local (Offline PWA)." }
    ]
  },
  {
    version: "v0.1.0",
    date: "2025-10-01",
    status: "Lanzamiento Inicial",
    statusColor: "bg-[#FCD116]/20 text-[#FCD116] border-[#FCD116]/30",
    summary: "Primera versión pública del repositorio.",
    changes: [
      { type: "Nuevo", text: "Motor básico de simulacros." },
      { type: "Nuevo", text: "Soporte offline con PWA y Service Workers." },
      { type: "Nuevo", text: "Registro de usuarios con Supabase." }
    ]
  }
];

function getBadgeColor(type: string) {
  switch(type) {
    case 'Nuevo': return 'bg-emerald-500/10 text-emerald-400 border-emerald-500/20';
    case 'Mejora': return 'bg-blue-500/10 text-blue-400 border-blue-500/20';
    case 'Fix': return 'bg-red-500/10 text-red-400 border-red-500/20';
    default: return 'bg-white/10 text-white/70 border-white/20';
  }
}
---

<Layout title={title} description={description}>
  <div class="min-h-screen bg-[#121212] py-16 px-4">
    <div class="max-w-4xl mx-auto">

      <section class="mb-16 pt-8 pb-4 text-center">
        <span class="inline-block px-3 py-1 text-xs font-mono tracking-widest uppercase bg-emerald-500/10 text-emerald-400 border border-emerald-500/20 rounded-full mb-6">
          📋 Historial de Versiones
        </span>
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-black text-[#F5F5DC] mb-6">
          Changelog
        </h1>
        <p class="text-xl text-white/60 max-w-2xl mx-auto">
          Registro ordenado de las actualizaciones de SaberParaTodos. Sigue de cerca las mejoras, nuevas funciones y correcciones de estabilidad.
        </p>
      </section>

      <div class="space-y-12 relative before:absolute before:inset-0 before:ml-4 md:before:ml-[8.5rem] before:-translate-x-px md:before:mx-auto md:before:translate-x-0 before:h-full before:w-0.5 before:bg-gradient-to-b before:from-transparent before:via-white/10 before:to-transparent">

        {releases.map((release, index) => (
          <article class="relative flex items-center justify-between md:justify-normal md:odd:flex-row-reverse group is-active" data-sr="fade-up" data-sr-delay={index * 100}>

            <!-- Timeline Marker -->
            <div class="flex items-center justify-center w-8 h-8 rounded-full border border-white/20 bg-[#121212] text-white/60 shrink-0 md:order-1 md:group-odd:-translate-x-1/2 md:group-even:translate-x-1/2 shadow-[0_0_15px_rgba(255,255,255,0.05)] z-10 transition-colors group-hover:border-emerald-500/50 group-hover:text-emerald-400">
              <svg class="w-3 h-3 fill-current" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><circle cx="12" cy="12" r="8"/></svg>
            </div>

            <!-- Content Card -->
            <div class="w-[calc(100%-3rem)] md:w-[calc(50%-2rem)] bg-white/5 border border-white/10 p-6 rounded-2xl transition-all hover:bg-white/10 hover:border-white/20">

              <div class="flex flex-wrap items-center gap-3 mb-3">
                <h2 class="text-2xl font-bold text-[#F5F5DC] font-mono tracking-tight">{release.version}</h2>
                <span class={`px-2 py-0.5 rounded text-xs font-semibold border uppercase tracking-wider ${release.statusColor}`}>
                  {release.status}
                </span>
                <time class="text-sm text-white/40 font-mono ml-auto">
                  {new Date(release.date + 'T00:00:00').toLocaleDateString('es-CO', { year: 'numeric', month: 'short', day: 'numeric' })}
                </time>
              </div>

              <p class="text-white/80 mb-5 text-sm md:text-base leading-relaxed">
                {release.summary}
              </p>

              <ul class="space-y-3 mb-6">
                {release.changes.map(change => (
                  <li class="flex items-start gap-3">
                    <span class={`px-2 py-0.5 mt-0.5 rounded text-[10px] uppercase font-bold tracking-wider shrink-0 border ${getBadgeColor(change.type)}`}>
                      {change.type}
                    </span>
                    <span class="text-sm text-white/70 leading-snug">{change.text}</span>
                  </li>
                ))}
              </ul>

              {release.postSlug && (
                <div class="mt-4 pt-4 border-t border-white/10">
                  <a href={`/novedades/${release.postSlug}`} class="text-sm text-[#FCD116] hover:text-yellow-400 font-medium inline-flex items-center gap-1 transition-colors">
                    Leer artículo completo
                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
                  </a>
                </div>
              )}
            </div>
          </article>
        ))}

      </div>
    </div>
  </div>
</Layout>
