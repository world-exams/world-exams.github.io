---
import Layout from '../layouts/Layout.astro';
import InstitutionalLogin from '../components/InstitutionalLogin.svelte';

const features = [
  {
    title: "Monitoreo en Tiempo Real",
    desc: "Visualiza el progreso de tus estudiantes mientras realizan sus simulacros.",
    icon: "📊"
  },
  {
    title: "Gestión de Grupos",
    desc: "Organiza tus clases por grados y materias. Asigna exámenes con un clic.",
    icon: "👥"
  },
  {
    title: "Analítica Detallada",
    desc: "Identifica brechas de conocimiento y fortalezas por estudiante y grupo.",
    icon: "📈"
  },
  {
    title: "Seguridad Anti-Fraude",
    desc: "Modo quiosco y detección de cambio de pestaña para exámenes controlados.",
    icon: "🔒"
  }
];
---

<Layout title="Instituciones - World Exams" description="Plataforma de gestión académica para colegios y preicfes.">
  <div class="min-h-screen bg-zinc-50 dark:bg-black relative overflow-hidden">
    <!-- Background Gradients -->
    <div class="absolute top-0 left-0 w-full h-full overflow-hidden pointer-events-none">
       <div class="absolute top-[-10%] left-[-10%] w-[40%] h-[40%] bg-blue-500/10 rounded-full blur-[100px]"></div>
       <div class="absolute bottom-[-10%] right-[-10%] w-[40%] h-[40%] bg-purple-500/10 rounded-full blur-[100px]"></div>
    </div>

    <div class="container mx-auto px-4 py-12 relative z-10">

      <div class="grid lg:grid-cols-2 gap-12 items-center min-h-[80vh]">

        <!-- Left Content -->
        <div class="space-y-8">
          <div class="inline-flex items-center space-x-2 px-3 py-1 rounded-full bg-blue-100 dark:bg-blue-900/30 text-blue-700 dark:text-blue-300 text-sm font-medium">
            <span class="relative flex h-2 w-2">
              <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-blue-400 opacity-75"></span>
              <span class="relative inline-flex rounded-full h-2 w-2 bg-blue-500"></span>
            </span>
            <span>Nuevo Dashboard 2026</span>
          </div>

          <h1 class="text-4xl lg:text-5xl font-extrabold tracking-tight text-zinc-900 dark:text-white leading-tight">
            Potencia el rendimiento <br />
            <span class="text-transparent bg-clip-text bg-gradient-to-r from-blue-600 to-purple-600 dark:from-blue-400 dark:to-purple-400">
              de tu institución
            </span>
          </h1>

          <p class="text-lg text-zinc-600 dark:text-zinc-400 max-w-xl">
            La plataforma integral para colegios y academias. Gestiona simulacros, analiza resultados y mejora el puntaje global de tu institución con la tecnología de World Exams.
          </p>

          <div class="grid sm:grid-cols-2 gap-4">
            {features.map(feature => (
              <div class="flex items-start space-x-3 p-3 rounded-lg hover:bg-white/50 dark:hover:bg-zinc-900/50 transition-colors">
                <span class="text-2xl">{feature.icon}</span>
                <div>
                  <h3 class="font-semibold text-zinc-900 dark:text-white text-sm">{feature.title}</h3>
                  <p class="text-xs text-zinc-500 dark:text-zinc-400 leading-snug">{feature.desc}</p>
                </div>
              </div>
            ))}
          </div>

          <div class="pt-4 flex items-center space-x-4 text-sm text-zinc-500 dark:text-zinc-500">
            <div class="flex -space-x-2">
              <div class="w-8 h-8 rounded-full bg-zinc-200 dark:bg-zinc-800 border-2 border-white dark:border-black flex items-center justify-center text-[10px]">C</div>
              <div class="w-8 h-8 rounded-full bg-zinc-200 dark:bg-zinc-800 border-2 border-white dark:border-black flex items-center justify-center text-[10px]">M</div>
              <div class="w-8 h-8 rounded-full bg-zinc-200 dark:bg-zinc-800 border-2 border-white dark:border-black flex items-center justify-center text-[10px]">+</div>
            </div>
            <span>Más de 50 instituciones confían en nosotros</span>
          </div>
        </div>

        <!-- Right Content: Login Card -->
        <div class="flex justify-center lg:justify-end relative group">
          <!-- Coming Soon Badge -->
          <div class="absolute -top-3 left-1/2 -translate-x-1/2 z-20 px-4 py-1.5 bg-gradient-to-r from-amber-500 to-amber-600 text-white font-bold text-[10px] uppercase tracking-[0.2em] rounded-full shadow-lg shadow-amber-500/20 border border-white/10 animate-pulse">
            Próximamente
          </div>

          <div class="w-full max-w-md relative opacity-60 grayscale-[0.5] pointer-events-none select-none">
            <!-- Decorative elements behind card -->
            <div class="absolute -top-4 -right-4 w-24 h-24 bg-stripes-pattern opacity-10"></div>

            <InstitutionalLogin client:load />

            <div class="mt-6 text-center">
              <p class="text-sm text-zinc-500">¿Aún no tienes cuenta?</p>
              <a href="mailto:business@worldexams.org" class="text-blue-600 dark:text-blue-400 font-medium hover:underline">Solicitar Demo Institucional &rarr;</a>
            </div>
          </div>
        </div>

      </div>
    </div>
  </div>
</Layout>

<style>
  .bg-stripes-pattern {
    background-image: linear-gradient(135deg, #000 25%, transparent 25%, transparent 50%, #000 50%, #000 75%, transparent 75%, transparent);
    background-size: 10px 10px;
  }
</style>
