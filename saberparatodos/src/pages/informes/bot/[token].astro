---
import Layout from '../../../layouts/Layout.astro';
import BotPracticeReport from '../../../components/BotPracticeReport.svelte';

const { token } = Astro.params;

const title = 'Informe de Práctica (Bot) | SaberParaTodos';
const description = 'Resultados de tu práctica en Telegram con reporte y publicidad.';
---

<Layout title={title} description={description}>
  <BotPracticeReport client:load token={token || ''} />
</Layout>
