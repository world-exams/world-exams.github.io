---
import Layout from '../../layouts/Layout.astro';

const sections = [
  {
    title: 'Dashboard',
    href: '/developers/dashboard',
    accent: 'bg-[#003893]',
    description: 'Genera claves, revisa consumo y administra tu acceso a la API.',
  },
  {
    title: 'Docs',
    href: '/developers/docs',
    accent: 'bg-[#CE1126]',
    description: 'Referencia pública, ejemplos de integración y especificación OpenAPI.',
  },
  {
    title: 'Planes',
    href: '/developers/api-questions',
    accent: 'bg-[#FCD116] text-black',
    description: 'Comparación de planes, volumen mensual y soporte institucional.',
  },
];
---

<Layout title="Developers | SaberParaTodos API">
  <div class="min-h-screen overflow-hidden bg-[#08111f] text-white">
    <section class="relative border-b border-white/10">
      <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_left,_rgba(252,209,22,0.18),_transparent_30%),radial-gradient(circle_at_bottom_right,_rgba(0,56,147,0.35),_transparent_35%)]"></div>
      <div class="relative mx-auto max-w-6xl px-6 py-20">
        <p class="text-xs font-black uppercase tracking-[0.35em] text-[#FCD116]">World Exams Developers</p>
        <div class="mt-6 grid gap-12 lg:grid-cols-[1.4fr_0.9fr]">
          <div>
            <h1 class="max-w-3xl text-5xl font-black leading-tight text-white">
              API de preguntas para productos educativos, simulacros y plataformas institucionales.
            </h1>
            <p class="mt-6 max-w-2xl text-lg text-white/72">
              Integra el contrato público en <code>api.saberparatodos.space</code>, administra tus claves
              desde un panel propio y mantén una superficie estable para tus desarrolladores.
            </p>
            <div class="mt-8 flex flex-wrap gap-3">
              <a href="/developers/dashboard" class="rounded-xl bg-[#FCD116] px-5 py-3 font-bold text-black transition hover:bg-[#ffe27a]">
                Abrir dashboard
              </a>
              <a href="/developers/docs" class="rounded-xl border border-white/20 px-5 py-3 font-bold text-white/90 transition hover:border-[#FCD116]/50 hover:text-white">
                Ver documentación
              </a>
            </div>
          </div>

          <div class="rounded-[28px] border border-white/10 bg-black/25 p-6 backdrop-blur">
            <div class="grid grid-cols-2 gap-4">
              <div class="rounded-2xl border border-white/10 bg-white/5 p-4">
                <div class="text-xs uppercase tracking-[0.24em] text-white/45">Endpoint premium</div>
                <div class="mt-3 text-sm font-semibold text-[#FCD116]">`/v1/premium/questions`</div>
              </div>
              <div class="rounded-2xl border border-white/10 bg-white/5 p-4">
                <div class="text-xs uppercase tracking-[0.24em] text-white/45">Endpoint público</div>
                <div class="mt-3 text-sm font-semibold text-[#FCD116]">`/v1/questions`</div>
              </div>
              <div class="rounded-2xl border border-white/10 bg-white/5 p-4">
                <div class="text-xs uppercase tracking-[0.24em] text-white/45">Autorización</div>
                <div class="mt-3 text-sm font-semibold">Bearer o `x-api-key`</div>
              </div>
              <div class="rounded-2xl border border-white/10 bg-white/5 p-4">
                <div class="text-xs uppercase tracking-[0.24em] text-white/45">Cobertura</div>
                <div class="mt-3 text-sm font-semibold">Preguntas por país, grado y asignatura</div>
              </div>
            </div>

            <div class="mt-6 rounded-2xl border border-[#FCD116]/20 bg-[#0d1728] p-4">
              <div class="text-xs uppercase tracking-[0.24em] text-[#FCD116]">Quick cURL</div>
              <pre class="mt-3 overflow-x-auto text-xs text-white/80"><code>curl -X GET \
  "https://api.saberparatodos.space/v1/premium/questions?grade=11&amp;subject=matematicas&amp;limit=5" \
  -H "Authorization: Bearer YOUR_API_KEY"</code></pre>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="mx-auto max-w-6xl px-6 py-14">
      <div class="grid gap-6 md:grid-cols-3">
        {sections.map((section) => (
          <a href={section.href} class="group rounded-[24px] border border-white/10 bg-white/5 p-6 transition hover:-translate-y-1 hover:border-white/20 hover:bg-white/[0.07]">
            <div class={`inline-flex rounded-full px-3 py-1 text-xs font-black uppercase tracking-[0.28em] ${section.accent}`}>
              {section.title}
            </div>
            <h2 class="mt-5 text-2xl font-black text-white">{section.title}</h2>
            <p class="mt-3 text-sm leading-6 text-white/65">{section.description}</p>
            <div class="mt-6 text-sm font-bold text-[#FCD116]">Abrir →</div>
          </a>
        ))}
      </div>
    </section>

    <section class="border-t border-white/10 bg-[#0a1321]">
      <div class="mx-auto grid max-w-6xl gap-10 px-6 py-14 lg:grid-cols-2">
        <div>
          <p class="text-xs font-black uppercase tracking-[0.35em] text-[#FCD116]">Flujo recomendado</p>
          <ol class="mt-6 space-y-4 text-white/75">
            <li><span class="font-bold text-white">1.</span> Entra al dashboard y accede con GitHub o con un enlace por correo.</li>
            <li><span class="font-bold text-white">2.</span> Genera tu primera clave desde el panel de developers.</li>
            <li><span class="font-bold text-white">3.</span> Prueba el endpoint premium con <code>Authorization: Bearer YOUR_API_KEY</code>.</li>
            <li><span class="font-bold text-white">4.</span> Usa <a href="/developers/docs" class="text-[#FCD116] underline">/developers/docs</a> para parámetros, ejemplos y OpenAPI.</li>
          </ol>
        </div>
        <div class="rounded-[28px] border border-white/10 bg-white/5 p-6">
          <p class="text-xs font-black uppercase tracking-[0.35em] text-[#FCD116]">Listo para producción</p>
          <ul class="mt-6 space-y-4 text-sm text-white/72">
            <li>Contrato público centralizado en <code>api.saberparatodos.space</code>.</li>
            <li>Autorización consistente con <code>Authorization</code> o <code>x-api-key</code>.</li>
            <li>Panel propio para administrar claves y revisar consumo.</li>
            <li>Especificación OpenAPI pública para integración y pruebas rápidas.</li>
          </ul>
        </div>
      </div>
    </section>
  </div>
</Layout>
