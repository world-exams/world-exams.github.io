---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Dashboard de Developers | SaberParaTodos API">
  <div class="min-h-screen bg-[#121212] p-8 text-[#F5F5DC]">
    <div class="mx-auto max-w-4xl">
      <header class="mb-8 flex items-center justify-between border-b border-[#333] pb-4">
        <div>
          <p class="text-xs font-black uppercase tracking-[0.3em] text-[#FCD116]">Portal de developers</p>
          <h1 class="mt-2 text-3xl font-bold text-[#FCD116]">Claves y consumo de la API</h1>
        </div>
        <button id="logout-btn" class="text-sm text-[#A0A0A0] underline hover:text-white">
          Cerrar sesión
        </button>
      </header>

      <div id="loading-state" class="py-12 text-center">
        <p class="text-[#A0A0A0]">Cargando cuenta de desarrollador...</p>
      </div>

      <div id="login-state" class="hidden rounded-lg border border-[#333] bg-[#1A1A1A] py-12 text-center">
        <h2 class="mb-4 text-2xl font-bold">Acceso requerido</h2>
        <p class="mx-auto mb-4 max-w-xl text-[#A0A0A0]">
          Inicia sesión para generar claves, revisar consumo y administrar tu cuenta de desarrollador.
        </p>
        <div class="flex flex-col items-center gap-3">
          <a
            href="/api/developers/auth/github"
            class="rounded-lg bg-[#003893] px-6 py-3 font-bold text-white transition-colors hover:bg-[#002776]"
          >
            Continuar con GitHub
          </a>
          <div class="w-full max-w-sm border-t border-[#333] pt-4">
            <label for="magic-email" class="mb-2 block text-left text-sm text-[#A0A0A0]">O recibe un enlace por correo</label>
            <div class="flex flex-col gap-3 sm:flex-row">
              <input
                id="magic-email"
                type="email"
                placeholder="developer@ejemplo.com"
                class="flex-1 rounded-lg border border-[#333] bg-[#121212] px-4 py-3 text-[#F5F5DC] outline-none transition focus:border-[#FCD116]"
              />
              <button
                id="magic-link-btn"
                class="rounded-lg border border-[#FCD116]/40 px-4 py-3 font-bold text-[#FCD116] transition-colors hover:bg-[#FCD116]/10"
              >
                Enviar enlace
              </button>
            </div>
            <p id="magic-link-status" class="mt-3 text-sm text-[#A0A0A0]"></p>
          </div>
        </div>
      </div>

      <div id="dashboard-content" class="hidden space-y-8">
        <div class="mb-8 flex items-center gap-4">
          <div class="flex h-12 w-12 items-center justify-center rounded-full bg-[#333] text-xl">👤</div>
          <div>
            <p id="user-email" class="text-lg font-bold"></p>
            <p class="text-sm text-[#A0A0A0]">Acceso a la API de preguntas</p>
          </div>
        </div>

        <div class="overflow-hidden rounded-lg border border-[#333] bg-[#1A1A1A]">
          <div class="flex items-center justify-between border-b border-[#333] p-6">
            <h2 class="text-xl font-bold">Tus claves</h2>
            <button
              id="create-key-btn"
              class="rounded bg-[#006847] px-4 py-2 text-sm font-bold text-white transition-colors hover:bg-[#005036]"
            >
              + Crear nueva clave
            </button>
          </div>

          <div id="keys-list" class="space-y-4 p-6">
            <p class="text-center italic text-[#A0A0A0]">No hay claves registradas todavía.</p>
          </div>
        </div>

        <div class="rounded-lg border border-[#333] bg-[#1A1A1A] p-6">
          <h2 class="text-xl font-bold text-[#FCD116]">Inicio rápido</h2>
          <ol class="mt-4 space-y-2 text-sm text-[#A0A0A0]">
            <li>1. Inicia sesión con GitHub o con un enlace por correo.</li>
            <li>2. Crea tu primera clave desde este panel.</li>
            <li>3. Úsala con <code>Authorization: Bearer YOUR_API_KEY</code> o <code>x-api-key</code>.</li>
            <li>4. Revisa parámetros, ejemplos y límites en <a href="/developers/docs" class="text-[#FCD116] hover:underline">/developers/docs</a>.</li>
          </ol>
        </div>

        <div class="rounded-lg border border-[#333] bg-[#1A1A1A] p-6">
          <h2 class="mb-4 text-xl font-bold text-[#FCD116]">Consumo acumulado</h2>
          <div class="grid grid-cols-1 gap-4 text-center md:grid-cols-3">
            <div class="rounded border border-[#333] bg-[#121212] p-4">
              <p class="mb-1 text-sm text-[#A0A0A0]">Solicitudes registradas</p>
              <p class="font-mono text-2xl font-bold" id="requests-count">0</p>
            </div>
            <div class="rounded border border-[#333] bg-[#121212] p-4">
              <p class="mb-1 text-sm text-[#A0A0A0]">Límite mensual total</p>
              <p class="font-mono text-2xl font-bold" id="monthly-limit">0</p>
            </div>
            <div class="rounded border border-[#333] bg-[#121212] p-4">
              <p class="mb-1 text-sm text-[#A0A0A0]">Estado del acceso</p>
              <p class="font-mono text-2xl font-bold text-green-500">Activo</p>
            </div>
          </div>
        </div>

        <div class="mt-8 rounded-lg border border-[#333] bg-[#1A1A1A] p-6">
          <h2 class="mb-4 flex items-center gap-2 text-xl font-bold">
            <span class="text-[#CE1126]">💳</span> Escalamiento comercial
          </h2>
          <div class="flex flex-col items-center justify-between rounded border border-yellow-500/20 bg-[#121212] p-6 md:flex-row">
            <div class="mb-4 md:mb-0">
              <h3 class="mb-1 text-lg font-bold text-[#FCD116]">Pro y Enterprise</h3>
              <p class="text-sm text-[#A0A0A0]">Aumenta volumen, soporte y capacidad operativa para integraciones reales.</p>
            </div>
            <a href="/contacto" class="rounded bg-[#FCD116] px-6 py-2 font-bold text-black transition-colors hover:bg-yellow-400">
              Hablar con ventas
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>

  <script>
    type DashboardView = 'loading' | 'login' | 'dashboard';
    type DashboardStats = { requests?: number; monthly_limit?: number };
    type DashboardKey = {
      name?: string;
      key_prefix?: string;
      current_usage?: number;
      monthly_limit?: number;
      is_active?: boolean;
      organizations?: { name?: string } | null;
    };

    const loadingState = document.getElementById('loading-state');
    const loginState = document.getElementById('login-state');
    const dashboardContent = document.getElementById('dashboard-content');
    const userEmail = document.getElementById('user-email');
    const keysList = document.getElementById('keys-list');
    const magicLinkStatus = document.getElementById('magic-link-status');
    const requestsCount = document.getElementById('requests-count');
    const monthlyLimit = document.getElementById('monthly-limit');
    const query = new URLSearchParams(window.location.search);

    const errorMessages: Record<string, string> = {
      auth: 'No fue posible completar el acceso.',
      github: 'No fue posible iniciar sesión con GitHub.',
      'magic-link': 'El enlace de acceso ya no es válido o expiró.'
    };

    async function fetchJson(url: string, options?: RequestInit) {
      const response = await fetch(url, options);
      const payload = await response.json().catch(() => ({}));
      return { response, payload };
    }

    function setView(view: DashboardView) {
      loadingState?.classList.toggle('hidden', view !== 'loading');
      loginState?.classList.toggle('hidden', view !== 'login');
      dashboardContent?.classList.toggle('hidden', view !== 'dashboard');
    }

    function updateStats(stats: DashboardStats) {
      if (requestsCount) requestsCount.textContent = Number(stats?.requests || 0).toLocaleString();
      if (monthlyLimit) monthlyLimit.textContent = Number(stats?.monthly_limit || 0).toLocaleString();
    }

    function renderKeys(keys: DashboardKey[]) {
      if (!keysList) return;

      if (!Array.isArray(keys) || keys.length === 0) {
        keysList.innerHTML = '<p class="text-center italic text-[#A0A0A0]">No hay claves registradas todavía.</p>';
        return;
      }

      keysList.innerHTML = keys.map((key) => `
        <div class="mb-3 flex flex-col items-center justify-between rounded border border-[#333] bg-[#121212] p-4 md:flex-row">
          <div class="mb-3 w-full md:mb-0">
            <p class="mb-1 font-mono font-bold text-[#FCD116]">${key.name || 'Clave sin nombre'}</p>
            <div class="flex items-center gap-2">
              <span class="rounded bg-[#333] px-2 py-0.5 text-xs text-[#A0A0A0]">${key.organizations?.name || 'Cuenta'}</span>
              <p class="font-mono text-sm text-[#A0A0A0]">${key.key_prefix}****</p>
            </div>
          </div>
          <div class="w-full border-t border-[#333] pt-3 text-right md:w-auto md:border-t-0 md:pt-0">
            <p class="mb-1 text-xs text-[#A0A0A0]">Uso: ${Number(key.current_usage || 0).toLocaleString()} / ${Number(key.monthly_limit || 0).toLocaleString()}</p>
            <span class="inline-block rounded px-2 py-1 text-xs font-bold ${key.is_active ? 'bg-green-900 text-green-300' : 'bg-red-900 text-red-300'}">
              ${key.is_active ? 'ACTIVA' : 'INACTIVA'}
            </span>
          </div>
        </div>
      `).join('');
    }

    async function loadKeys() {
      const { response, payload } = await fetchJson('/api/developers/keys');
      if (!response.ok) {
        throw new Error(payload.error || 'No fue posible cargar tus claves.');
      }

      renderKeys(payload.keys);
      updateStats(payload.stats);
    }

    async function bootstrap() {
      if (query.has('error') && magicLinkStatus) {
        const key = query.get('error') || '';
        magicLinkStatus.textContent = errorMessages[key] || 'No fue posible completar el acceso.';
      }

      const { response, payload } = await fetchJson('/api/developers/session');
      if (!response.ok || !payload.authenticated) {
        setView('login');
        return;
      }

      if (userEmail) userEmail.textContent = payload.user?.email || '';
      await loadKeys();
      setView('dashboard');
    }

    document.getElementById('magic-link-btn')?.addEventListener('click', async () => {
      const emailInput = document.getElementById('magic-email');
      const email = emailInput instanceof HTMLInputElement ? emailInput.value.trim() : '';

      if (!email) {
        if (magicLinkStatus) magicLinkStatus.textContent = 'Ingresa un correo antes de continuar.';
        return;
      }

      if (magicLinkStatus) magicLinkStatus.textContent = 'Enviando enlace de acceso...';
      const { response, payload } = await fetchJson('/api/developers/auth/magic-link', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email })
      });

      if (!response.ok) {
        if (magicLinkStatus) magicLinkStatus.textContent = payload.error || 'No fue posible enviar el enlace.';
        return;
      }

      if (magicLinkStatus) magicLinkStatus.textContent = payload.message || 'Enlace enviado.';
    });

    document.getElementById('logout-btn')?.addEventListener('click', async () => {
      await fetch('/api/developers/logout', { method: 'POST' });
      window.location.href = '/developers/dashboard';
    });

    document.getElementById('create-key-btn')?.addEventListener('click', async (event) => {
      const button = event.currentTarget;
      if (!(button instanceof HTMLButtonElement)) return;

      const originalText = button.textContent;
      button.textContent = 'Creando clave...';
      button.disabled = true;

      try {
        const { response, payload } = await fetchJson('/api/developers/keys', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ name: 'Clave principal' })
        });

        if (!response.ok) {
          throw new Error(payload.error || 'No fue posible crear la clave.');
        }

        await loadKeys();
        window.alert(`Nueva clave creada:\n${payload.apiKey}\n\nGuárdala ahora. Solo se muestra una vez.\nPrefijo: ${payload.prefix}`);
      } catch (error) {
        window.alert(error instanceof Error ? error.message : 'No fue posible crear la clave.');
      } finally {
        button.textContent = originalText;
        button.disabled = false;
      }
    });

    bootstrap().catch(() => setView('login'));
  </script>
</Layout>
