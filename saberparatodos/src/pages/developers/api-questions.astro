---
import Layout from '../../layouts/Layout.astro';

const plans = [
  {
    name: 'Free',
    price: '0',
    accent: 'border-white/10',
    cta: 'Usar endpoint público',
    href: 'https://api.saberparatodos.space/v1/questions?country=co&exam=icfes&grade=11&subject=matematicas&page=1',
    features: [
      'Sin API key',
      'Límite por IP',
      'Ideal para pruebas públicas y prototipos',
      'Ruta: /v1/questions',
    ],
  },
  {
    name: 'Pro',
    price: '19 USD',
    accent: 'border-[#FCD116]/40',
    cta: 'Crear key',
    href: '/developers/dashboard',
    features: [
      'API key propia',
      'Mayor volumen mensual',
      'Headers Authorization o x-api-key',
      'Ruta: /v1/premium/questions',
    ],
  },
  {
    name: 'Enterprise',
    price: 'Custom',
    accent: 'border-[#003893]/50',
    cta: 'Hablar con ventas',
    href: '/contacto',
    features: [
      'Mayor throughput',
      'Soporte institucional',
      'Acuerdos de volumen',
      'Integraciones dedicadas',
    ],
  },
];
---

<Layout title="Planes API | SaberParaTodos">
  <div class="min-h-screen bg-[#07101d] text-white">
    <section class="border-b border-white/10 bg-[linear-gradient(135deg,#08111f_0%,#102243_60%,#0a1422_100%)] px-6 py-16">
      <div class="mx-auto max-w-6xl">
        <p class="text-xs font-black uppercase tracking-[0.35em] text-[#FCD116]">Planes</p>
        <h1 class="mt-4 text-5xl font-black">Consumo ordenado para portal y API externa</h1>
        <p class="mt-5 max-w-3xl text-lg text-white/70">
          Centraliza toda integración en <code>api.saberparatodos.space</code>. El portal general usa el endpoint público
          y las integraciones autenticadas usan el endpoint premium con API key.
        </p>
      </div>
    </section>

    <section class="mx-auto max-w-6xl px-6 py-12">
      <div class="grid gap-6 lg:grid-cols-3">
        {plans.map((plan) => (
          <article class={`rounded-[28px] border bg-white/5 p-6 ${plan.accent}`}>
            <div class="text-xs font-black uppercase tracking-[0.32em] text-[#FCD116]">{plan.name}</div>
            <div class="mt-4 text-4xl font-black">{plan.price}</div>
            <ul class="mt-6 space-y-3 text-sm text-white/72">
              {plan.features.map((feature) => (
                <li>{feature}</li>
              ))}
            </ul>
            <a href={plan.href} class="mt-8 inline-flex rounded-xl bg-[#FCD116] px-4 py-3 font-bold text-black transition hover:bg-[#ffe27a]">
              {plan.cta}
            </a>
          </article>
        ))}
      </div>
    </section>

    <section class="border-t border-white/10 bg-[#0b1424] px-6 py-12">
      <div class="mx-auto grid max-w-6xl gap-6 lg:grid-cols-2">
        <div class="rounded-[24px] border border-white/10 bg-white/5 p-6">
          <h2 class="text-2xl font-black">Rutas activas</h2>
          <ul class="mt-5 space-y-3 text-sm text-white/72">
            <li><code>GET https://api.saberparatodos.space/v1/questions</code> para consumo público.</li>
            <li><code>GET https://api.saberparatodos.space/v1/premium/questions</code> para consumo autenticado.</li>
            <li><code>GET https://api.saberparatodos.space/health</code> para revisar el estado del servicio.</li>
          </ul>
        </div>
        <div class="rounded-[24px] border border-white/10 bg-white/5 p-6">
          <h2 class="text-2xl font-black">Criterio de uso</h2>
          <ul class="mt-5 space-y-3 text-sm text-white/72">
            <li>Usa el endpoint público para experiencias abiertas y validaciones iniciales.</li>
            <li>Usa el endpoint premium para integraciones productivas y consumo autenticado.</li>
            <li>Mantén el subdominio público como contrato estable en código, documentación y monitoreo.</li>
          </ul>
        </div>
      </div>
    </section>
  </div>
</Layout>
