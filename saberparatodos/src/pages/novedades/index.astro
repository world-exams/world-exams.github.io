---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('changelog');
// Ordenar por fecha, más reciente primero
posts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const featuredPosts = posts.slice(0, 3);
const latestPost = posts[0];

const title = "Novedades y Actualizaciones | SaberParaTodos";
const description = "Entérate de los últimos cambios, mejoras y nuevas herramientas en SaberParaTodos.";
---

<Layout title={title} description={description}>
  <div class="min-h-screen bg-[#121212] py-16 px-4">
    <div class="max-w-4xl mx-auto">
      <section class="mb-16 pt-8 pb-4 text-center">
        <span class="inline-block rounded-full border border-[#FCD116]/20 bg-[#FCD116]/10 px-3 py-1 text-[11px] font-mono uppercase tracking-[0.28em] text-[#FCD116]">
          Centro de producto
        </span>
        <h1 class="text-4xl md:text-5xl font-bold text-[#F5F5DC] mb-4">
          Novedades y Actualizaciones
        </h1>
        <p class="text-xl text-white/60">
          Lo último en plataforma, preguntas y guías de estudio.
        </p>

        <div class="mt-8 grid gap-4 md:grid-cols-2">
          <a
            href="/novedades"
            class="rounded-2xl border border-emerald-500/20 bg-emerald-500/10 p-5 text-left transition hover:border-emerald-500/40 hover:bg-emerald-500/15"
          >
            <p class="text-xs font-mono uppercase tracking-[0.24em] text-emerald-400">Artículos</p>
            <h2 class="mt-2 text-2xl font-bold text-[#F5F5DC]">Novedades</h2>
            <p class="mt-2 text-sm leading-relaxed text-white/65">
              Publicaciones con contexto, explicación y detalles de cada cambio.
            </p>
          </a>

          <a
            href="/changelog"
            class="rounded-2xl border border-white/10 bg-white/5 p-5 text-left transition hover:border-[#FCD116]/30 hover:bg-white/10"
          >
            <p class="text-xs font-mono uppercase tracking-[0.24em] text-[#FCD116]">Versiones</p>
            <h2 class="mt-2 text-2xl font-bold text-[#F5F5DC]">Changelog</h2>
            <p class="mt-2 text-sm leading-relaxed text-white/65">
              Línea de tiempo de releases con resumen por versión, fixes y mejoras.
            </p>
            <span class="mt-4 inline-flex items-center gap-2 text-sm font-semibold text-[#FCD116]">
              Abrir historial
              <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
              </svg>
            </span>
          </a>
        </div>
      </section>

      {latestPost && (
        <section class="mb-12 rounded-3xl border border-[#FCD116]/15 bg-[linear-gradient(135deg,rgba(252,209,22,0.08),rgba(255,255,255,0.03))] p-6 sm:p-8">
          <div class="flex flex-col gap-6 md:flex-row md:items-end md:justify-between">
            <div class="max-w-2xl">
              <p class="text-xs font-mono uppercase tracking-[0.3em] text-[#FCD116]">Último release</p>
              <h2 class="mt-3 text-3xl font-black text-[#F5F5DC]">
                {latestPost.data.title}
              </h2>
              {latestPost.data.description && (
                <p class="mt-3 text-white/75 leading-relaxed">
                  {latestPost.data.description}
                </p>
              )}
            </div>
            <div class="flex flex-col gap-3 sm:flex-row">
              <a
                href={`/novedades/${latestPost.slug}`}
                class="rounded-xl bg-[#FCD116] px-5 py-3 text-sm font-bold text-black transition hover:bg-yellow-400"
              >
                Leer novedad
              </a>
              <a
                href="/changelog"
                class="rounded-xl border border-white/15 px-5 py-3 text-sm font-bold text-white/85 transition hover:border-[#FCD116]/35 hover:text-white"
              >
                Ver changelog completo
              </a>
            </div>
          </div>
        </section>
      )}

      {featuredPosts.length > 0 && (
        <section class="mb-14">
          <div class="mb-6 flex items-center justify-between gap-4">
            <div>
              <p class="text-xs font-mono uppercase tracking-[0.28em] text-white/35">Vista rápida</p>
              <h2 class="mt-2 text-2xl font-bold text-[#F5F5DC]">Changelog visible</h2>
            </div>
            <a href="/changelog" class="text-sm font-semibold text-[#FCD116] hover:text-yellow-400">
              Ir a timeline
            </a>
          </div>

          <div class="grid gap-4 md:grid-cols-3">
            {featuredPosts.map((post) => (
              <a
                href={`/novedades/${post.slug}`}
                class="rounded-2xl border border-white/10 bg-white/5 p-5 transition hover:border-white/20 hover:bg-white/10"
              >
                <p class="text-xs font-mono uppercase tracking-[0.24em] text-white/40">
                  {post.data.date.toLocaleDateString('es-CO', {
                    year: 'numeric', month: 'short', day: 'numeric'
                  })}
                </p>
                <h3 class="mt-3 text-lg font-bold text-[#F5F5DC]">{post.data.title}</h3>
                <p class="mt-2 line-clamp-3 text-sm leading-relaxed text-white/65">
                  {post.data.description}
                </p>
              </a>
            ))}
          </div>
        </section>
      )}

      <div class="space-y-8">
        {posts.map((post, index) => (
          <article
            class="bg-white/5 border border-white/10 rounded-2xl p-6 sm:p-8 hover:bg-white/10 transition-colors"
            data-sr="fade-up"
            data-sr-delay={index * 100}
          >
            <div class="flex items-center gap-4 text-sm text-white/50 mb-3 font-mono">
              <time datetime={post.data.date.toISOString()}>
                {post.data.date.toLocaleDateString('es-CO', {
                  year: 'numeric', month: 'long', day: 'numeric'
                })}
              </time>
              <span>•</span>
              <span>{post.data.author}</span>
            </div>

            <h2 class="text-2xl font-bold text-[#F5F5DC] mb-3">
              <a href={`/novedades/${post.slug}`} class="hover:underline">
                {post.data.title}
              </a>
            </h2>

            {post.data.description && (
              <p class="text-white/80 mb-6 leading-relaxed">
                {post.data.description}
              </p>
            )}

            <div class="flex items-center justify-between mt-6 pt-6 border-t border-white/10">
              <div class="flex flex-wrap gap-2">
                {post.data.tags.map(tag => (
                  <span class="px-3 py-1 bg-white/5 text-white/60 text-xs rounded-full border border-white/10 uppercase tracking-wider">
                    {tag}
                  </span>
                ))}
              </div>
              <a
                href={`/novedades/${post.slug}`}
                class="px-4 py-2 bg-[#FCD116] text-black font-semibold rounded-lg text-sm hover:bg-yellow-400 transition"
              >
                Leer más
              </a>
            </div>
          </article>
        ))}
        {posts.length === 0 && (
          <div class="text-center text-white/50 p-12 border border-white/5 rounded-2xl">
            Aún no hay publicaciones disponibles.
          </div>
        )}
      </div>
    </div>
  </div>
</Layout>
