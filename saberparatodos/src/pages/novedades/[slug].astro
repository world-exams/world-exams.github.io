---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Reactions from '../../components/changelog/Reactions.svelte';
import Comments from '../../components/changelog/Comments.svelte';

const slug = Astro.params.slug || '';
const posts = await getCollection('changelog');
const post = posts.find((entry) => entry.slug === slug);

if (!post) {
  return Astro.redirect('/novedades');
}

const { Content } = await post.render();
---

<Layout
  title={`${post.data.title} | Novedades`}
  description={post.data.description || post.data.title}
>
  <article class="min-h-screen bg-[#121212] pt-12 pb-24 px-4 overflow-x-hidden">
    <div class="max-w-3xl mx-auto">

      <!-- Back button -->
      <a href="/novedades" class="inline-flex items-center gap-2 text-white/50 hover:text-white/80 transition-colors mb-8 text-sm">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
        Volver a Novedades
      </a>

      <!-- Header -->
      <header class="mb-12 border-b border-white/10 pb-8">
        <div class="flex items-center gap-4 text-sm text-white/50 mb-4 font-mono">
          <time datetime={post.data.date.toISOString()}>
            {post.data.date.toLocaleDateString('es-CO', {
              year: 'numeric', month: 'long', day: 'numeric'
            })}
          </time>
          <span>•</span>
          <span>{post.data.author}</span>
        </div>

        <h1 class="text-3xl sm:text-4xl md:text-5xl font-bold text-[#F5F5DC] leading-tight mb-6">
          {post.data.title}
        </h1>

        <div class="flex flex-wrap gap-2">
          {post.data.tags.map(tag => (
            <span class="px-3 py-1 bg-white/5 text-white/60 text-xs rounded-full border border-white/10 uppercase tracking-wider">
              {tag}
            </span>
          ))}
        </div>
      </header>

      <!-- Content -->
      <div
        class="prose prose-invert prose-lg max-w-none prose-headings:text-[#F5F5DC] prose-a:text-[#FCD116] hover:prose-a:text-yellow-400 mb-16"
        data-sr="fade-up"
        data-sr-delay="100"
      >
        <Content />
      </div>

      <!-- Reactions -->
      <div
        class="border-t border-b border-white/10 py-8 mb-12 flex justify-center"
        data-sr="fade-up"
        data-sr-delay="150"
      >
        <Reactions postSlug={post.slug} client:visible />
      </div>

      <!-- Comments -->
      <div data-sr="fade-up" data-sr-delay="200">
        <Comments postSlug={post.slug} client:visible />
      </div>

    </div>
  </article>
</Layout>
