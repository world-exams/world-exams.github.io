{
  "name": "saberparatodos",
  "type": "module",
  "version": "0.11.0",
  "scripts": {
    "predev": "",
    "dev": "astro dev",
    "start": "astro dev",
    "prebuild": "node scripts/generate-build-info.js && node scripts/generate-static-packs.js",
    "build": "astro build",
    "postbuild": "echo 'Build complete'",
    "preview": "astro preview",
    "sync:api": "pwsh -File scripts/copy-api.ps1",
    "predeploy": "npm run lint && npm run test:unit && npm run build",
    "deploy": "npx wrangler pages deploy dist --project-name=saberparatodos --branch=main",
    "deploy:manual": "pwsh -File scripts/deploy-manual.ps1",
    "deploy:fast": "pwsh -File scripts/deploy-manual.ps1 -Fast",
    "verify:deploy": "pwsh -File scripts/verify-deployment.ps1",
    "astro": "astro",
    "validate": "node scripts/validate_content.js",
    "validate:strict": "node scripts/validate_content.js --strict-v3 --fail-on-error",
    "validate:g11": "node scripts/validate_content.js --grade=11 --country=colombia",
    "verify:grade11-preicfes": "node scripts/verify-grade11-preicfes-policy.js",
    "validate:full": "node scripts/validate_content.js && astro check && astro build",
    "video:queue:v41": "node scripts/video/build-video-queue.js",
    "video:queue:v41:jobs": "node scripts/video/build-video-queue.js --emit-jobs",
    "video:queue:social": "node scripts/video/build-social-publish-queue.js",
    "video:init:period1:g11": "node scripts/video/init-period1-grade11-assets.js",
    "video:manifest:upsert": "node scripts/video/upsert-video-manifest.js",
    "video:jobs:run": "node scripts/video/run-local-video-jobs.js",
    "video:generate:fallback": "python scripts/video/generate-videos-fallback.py",
    "video:publish:sync": "node scripts/video/sync-publish-links-to-manifest.js",
    "video:social:keys:check": "node scripts/video/validate-social-keys.js",
    "lint": "astro check && tsc --noEmit",
    "prepare": "husky",
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "test:debug": "playwright test --debug",
    "test:headed": "playwright test --headed",
    "test:party": "playwright test party-mode.spec.ts",
    "test:video:frames": "playwright test tests/video-frame-review.spec.ts",
    "test:party:headed": "playwright test party-mode.spec.ts --headed",
    "test:unit": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^12.6.12",
    "@astrojs/sitemap": "^3.6.0",
    "@astrojs/svelte": "^7.2.2",
    "@astrojs/tailwind": "^5.0.0",
    "@cloudflare/workers-types": "^4.20240529.0",
    "@sentry/astro": "^8.40.0",
    "@sentry/svelte": "^8.40.0",
    "@supabase/supabase-js": "^2.86.0",
    "astro": "^5.16.0",
    "chart.js": "^4.5.1",
    "html2canvas": "^1.4.1",
    "jspdf": "^3.0.4",
    "katex": "^0.16.27",
    "peerjs": "^1.5.5",
    "svelte": "^5.44.1",
    "tailwindcss": "^3.0.0",
    "trystero": "^0.22.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.5",
    "@playwright/test": "^1.57.0",
    "@types/html2canvas": "^0.5.35",
    "@types/node": "^20.0.0",
    "@vitest/coverage-v8": "^4.0.16",
    "baseline-browser-mapping": "^2.10.0",
    "gray-matter": "^4.0.3",
    "husky": "^9.1.7",
    "jsdom": "^27.4.0",
    "lint-staged": "^15.2.10",
    "pagefind": "^1.4.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.16"
  },
  "lint-staged": {
    "src/content/questions/**/*.md": [
      "node scripts/validate_content.js"
    ],
    "*.{js,ts,astro,svelte}": [
      "astro check"
    ]
  }
}
